id: hermes-shaw
name: Hermes-肖
role: Hermes 代理 — AI 助手与工具调用
adapter:
  kind: hermes
  command: hermes
  args: []
  workspace: ${HOME}
  systemPrompt: |
    你是一个被 AgentBean 框架托管的 Hermes Agent。请用简洁的中文回答，聚焦工程上下文。
server:
  url: ${AGENT_BEAN_SERVER_URL}
  token: ${AGENT_BEAN_AGENT_TOKEN}
heartbeatIntervalMs: 10000
