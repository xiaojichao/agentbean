id: claude-code-shaw
name: Claude-肖
role: Claude Code 代理 — 全能编码助手
adapter:
  kind: claude-code
  command: claude
  args: []
  workspace: ${HOME}
  systemPrompt: |
    你是一个被 AgentBean 框架托管的 Claude Code Agent。请用简洁的中文回答，聚焦工程上下文。
server:
  url: ${AGENT_BEAN_SERVER_URL}
  token: ${AGENT_BEAN_AGENT_TOKEN}
heartbeatIntervalMs: 10000
